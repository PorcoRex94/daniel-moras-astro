---
const whatsappNumber = "5491166722505";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const messagesByPath: Record<string, string> = {
  "/": "Hola Daniel, quiero hacer una consulta general sobre soluciones de impresión.",
  "/insumos": "Hola Daniel, quiero consultar por tintas, partes o insumos.",
  "/blog": "Hola Daniel, estuve leyendo el blog y quiero hacer una consulta.",

  "/rubros/packaging": "Hola Daniel, quiero consultar por soluciones para packaging.",
  "/rubros/textil": "Hola Daniel, quiero consultar por soluciones para industria textil.",
  "/rubros/editorial": "Hola Daniel, quiero consultar por soluciones para editorial.",
  "/rubros/etiquetas": "Hola Daniel, quiero consultar por soluciones para etiquetas.",
  "/rubros/comunicacion-visual": "Hola Daniel, quiero consultar por soluciones para comunicación visual.",
};

const isBlogPost = pathname.startsWith("/blog/");
const isRubroPage = pathname.startsWith("/rubros/");

const fallbackMessage = isBlogPost
  ? "Hola Daniel, estuve leyendo una nota del blog y quiero hacer una consulta."
  : isRubroPage
    ? "Hola Daniel, quiero consultar por soluciones de impresión para mi rubro."
    : "Hola Daniel, quiero hacer una consulta sobre equipos de impresión.";

const defaultMessage = messagesByPath[pathname] ?? fallbackMessage;
---

<div
  class="floating-actions"
  aria-label="Accesos rápidos"
  data-whatsapp-number={whatsappNumber}
  data-default-message={defaultMessage}
>
  <a
    href="#top"
    class="floating-actions__top"
    aria-label="Volver arriba"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 5.25 5.4 11.85l1.45 1.45L11 9.15V20h2V9.15l4.15 4.15 1.45-1.45L12 5.25Z" />
    </svg>
  </a>

  <form class="floating-actions__form">
    <label class="sr-only" for="floating-whatsapp-message">
      Escribí tu consulta
    </label>

    <input
      id="floating-whatsapp-message"
      class="floating-actions__input"
      type="text"
      name="message"
      placeholder="Escribí tu consulta..."
      autocomplete="off"
    />

    <button
      type="submit"
      class="floating-actions__send"
      aria-label="Enviar consulta por WhatsApp"
    >
      Enviar
    </button>
  </form>

  <button
    type="button"
    class="floating-actions__chat"
    aria-label="Abrir consulta por WhatsApp"
    aria-expanded="false"
  >
    <span class="floating-actions__icon" aria-hidden="true">
      <svg viewBox="0 0 32 32" role="img">
        <path
          d="M16.02 3.2C9.04 3.2 3.36 8.78 3.36 15.64c0 2.2.6 4.34 1.74 6.22L3.2 28.8l7.14-1.86a12.85 12.85 0 0 0 5.68 1.34c6.98 0 12.66-5.58 12.66-12.44S23 3.2 16.02 3.2Zm0 22.96c-1.84 0-3.64-.48-5.2-1.4l-.38-.22-4.22 1.1 1.12-4.06-.26-.42a10.24 10.24 0 0 1-1.58-5.52c0-5.68 4.72-10.3 10.52-10.3s10.52 4.62 10.52 10.3-4.72 10.52-10.52 10.52Zm5.78-7.72c-.32-.16-1.86-.9-2.14-1-.28-.1-.48-.16-.68.16-.2.32-.78 1-.96 1.2-.18.2-.36.22-.68.08-.32-.16-1.34-.48-2.54-1.54-.94-.82-1.58-1.84-1.76-2.16-.18-.32-.02-.48.14-.64.14-.14.32-.36.48-.54.16-.18.22-.32.32-.54.1-.2.06-.4-.02-.56-.08-.16-.68-1.62-.94-2.22-.24-.58-.5-.5-.68-.5h-.58c-.2 0-.52.08-.8.38-.28.32-1.04 1.02-1.04 2.48s1.06 2.88 1.2 3.08c.16.2 2.1 3.16 5.08 4.44.72.3 1.28.48 1.72.62.72.22 1.36.18 1.88.12.58-.08 1.86-.76 2.12-1.48.26-.72.26-1.34.18-1.48-.08-.14-.28-.22-.6-.38Z"
        />
      </svg>
    </span>

    <span class="floating-actions__text">
      Consultar
    </span>
  </button>
</div>

<script>
  const floatingActions = document.querySelector(".floating-actions");

  if (floatingActions) {
    const chatButton = floatingActions.querySelector(".floating-actions__chat");
    const form = floatingActions.querySelector(".floating-actions__form");
    const input = floatingActions.querySelector(".floating-actions__input");

    const whatsappNumber = floatingActions.dataset.whatsappNumber;
    const defaultMessage = floatingActions.dataset.defaultMessage;

    const toggleScrollTopButton = () => {
      if (window.scrollY > 420) {
        floatingActions.classList.add("floating-actions--show-top");
      } else {
        floatingActions.classList.remove("floating-actions--show-top");
      }
    };

    toggleScrollTopButton();

    window.addEventListener("scroll", toggleScrollTopButton, {
      passive: true,
    });

    chatButton?.addEventListener("click", () => {
      const isOpen = floatingActions.classList.toggle("floating-actions--open");

      chatButton.setAttribute("aria-expanded", String(isOpen));

      if (isOpen && input instanceof HTMLInputElement) {
        input.focus();
      }
    });

    form?.addEventListener("submit", (event) => {
      event.preventDefault();

      const customMessage =
        input instanceof HTMLInputElement ? input.value.trim() : "";

      const finalMessage = customMessage || defaultMessage || "";
      const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(finalMessage)}`;

      window.open(whatsappUrl, "_blank", "noopener,noreferrer");
    });
  }
</script>