---
const {
  families = [],
  equipment = [],
  rubroLabel = "Industria textil",
} = Astro.props;

const getEquipment = (familyId, subgroupId) =>
  equipment
    .filter(
      (item) =>
        item.family === familyId &&
        item.subgroup === subgroupId,
    )
    .sort((a, b) => {
      const featuredA = a.featured ? -1 : 0;
      const featuredB = b.featured ? -1 : 0;

      if (featuredA !== featuredB) {
        return featuredA - featuredB;
      }

      return (a.order ?? 999) - (b.order ?? 999);
    });

const getFamilyCount = (familyId) =>
  equipment.filter((item) => item.family === familyId).length;

const getSubgroupCount = (familyId, subgroupId) =>
  equipment.filter(
    (item) =>
      item.family === familyId &&
      item.subgroup === subgroupId,
  ).length;

const visibleFamilies = families.filter(
  (family) => getFamilyCount(family.id) > 0,
);
---

<section
  class="rubro-equipment-groups"
  aria-labelledby="equipment-groups-title"
>
  <div class="rubro-section__inner">
    <header class="rubro-section__heading rubro-equipment-groups__heading">
      <p class="rubro-eyebrow">Equipos y soluciones</p>

      <h2 id="equipment-groups-title">
        Tecnología organizada según cada etapa de producción.
      </h2>

      <p>
        Explorá las familias disponibles para {rubroLabel}. La elección final
        depende del material, el volumen, el ancho, el acabado y el proceso que
        necesitás resolver.
      </p>
    </header>

    <div
      class="rubro-process-index"
      aria-label={`Índice de soluciones para ${rubroLabel}`}
    >
      <div class="rubro-process-index__intro">
        <span>Índice de soluciones</span>

        <p>
          Elegí una etapa del proceso para ir directo a los equipos
          correspondientes.
        </p>
      </div>

      <nav
        class="rubro-family-navigation"
        aria-label={`Familias de equipos para ${rubroLabel}`}
      >
        {
          visibleFamilies.map((family) => {
            const total = getFamilyCount(family.id);

            return (
              <a href={`#familia-${family.id}`} class="rubro-family-link">
                <span class="rubro-family-link__number">
                  {family.number}
                </span>

                <span class="rubro-family-link__content">
                  <strong>{family.title}</strong>

                  <small>
                    {total} {total === 1 ? "equipo" : "equipos"}
                  </small>
                </span>

                <span class="rubro-family-link__arrow" aria-hidden="true">
                  ↓
                </span>
              </a>
            );
          })
        }
      </nav>
    </div>

    <div class="rubro-equipment-families">
      {
        visibleFamilies.map((family) => {
          const familyCount = getFamilyCount(family.id);

          return (
            <section
              class="rubro-equipment-family"
              id={`familia-${family.id}`}
              aria-labelledby={`titulo-${family.id}`}
            >
              <header class="rubro-equipment-family__header">
                <span>{family.number}</span>

                <div>
                  <h3 id={`titulo-${family.id}`}>{family.title}</h3>
                  <p>{family.description}</p>
                </div>

                <small>
                  {familyCount}{" "}
                  {familyCount === 1 ? "equipo" : "equipos"}
                </small>
              </header>

              <div class="rubro-equipment-family__subgroups">
                {
                  family.subgroups.map((subgroup) => {
                    const subgroupEquipment = getEquipment(
                      family.id,
                      subgroup.id,
                    );

                    const subgroupCount = getSubgroupCount(
                      family.id,
                      subgroup.id,
                    );

                    if (subgroupCount === 0) {
                      return null;
                    }

                    return (
                      <section
                        class="rubro-equipment-subgroup"
                        aria-labelledby={`subgrupo-${family.id}-${subgroup.id}`}
                      >
                        <header class="rubro-equipment-subgroup__header">
                          <div>
                            <h4
                              id={`subgrupo-${family.id}-${subgroup.id}`}
                            >
                              {subgroup.title}
                            </h4>

                            <p>{subgroup.description}</p>
                          </div>

                          <span>
                            {subgroupCount}{" "}
                            {subgroupCount === 1 ? "modelo" : "modelos"}
                          </span>
                        </header>

                        <div class="rubro-equipment-subgroup__grid">
                          {
                            subgroupEquipment.map((item) => {
                              const cardClass = item.featured
                                ? "rubro-equipment-product rubro-equipment-product--featured"
                                : "rubro-equipment-product";

                              return (
                                <article class={cardClass}>
                                  <div class="rubro-equipment-product__image">
                                    {
                                      item.featured && (
                                        <span class="rubro-equipment-product__featured-ribbon">
                                          {item.featuredLabel ??
                                            "Equipo destacado"}
                                        </span>
                                      )
                                    }

                                    <img
                                      src={item.image}
                                      alt={`${item.name}, equipo de ${item.brand}`}
                                      width="720"
                                      height="480"
                                      loading="lazy"
                                      decoding="async"
                                    />

                                    {
                                      item.video && (
                                        <span class="rubro-equipment-product__video">
                                          Video disponible
                                        </span>
                                      )
                                    }
                                  </div>

                                  <div class="rubro-equipment-product__content">
                                    {
                                      item.featured && (
                                        <span class="rubro-equipment-product__featured">
                                          {item.featuredLabel ??
                                            "Equipo destacado"}
                                        </span>
                                      )
                                    }

                                    <p class="rubro-equipment-product__brand">
                                      {item.brand}
                                    </p>

                                    <h5>{item.name}</h5>

                                    <p>{item.shortDescription}</p>

                                    {
                                      item.featured && item.featuredText && (
                                        <p class="rubro-equipment-product__featured-text">
                                          {item.featuredText}
                                        </p>
                                      )
                                    }
                                  </div>

                                  <div class="rubro-equipment-product__footer">
                                    {
                                      item.pdf ? (
                                        <a
                                          href={item.pdf}
                                          target="_blank"
                                          rel="noopener noreferrer"
                                          class="rubro-equipment-product__document"
                                        >
                                          Ficha técnica
                                        </a>
                                      ) : (
                                        <span>Información a consultar</span>
                                      )
                                    }

                                    {
                                      item.pageReady ? (
                                        <a
                                          href={`/equipos/${item.id}`}
                                          aria-label={`Ver información de ${item.name}`}
                                        >
                                          Ver equipo
                                          <span aria-hidden="true">→</span>
                                        </a>
                                      ) : (
                                        <a
                                          href={`/#contacto?equipo=${encodeURIComponent(
                                            item.name,
                                          )}`}
                                          aria-label={`Consultar por ${item.name}`}
                                        >
                                          Consultar
                                          <span aria-hidden="true">→</span>
                                        </a>
                                      )
                                    }
                                  </div>
                                </article>
                              );
                            })
                          }
                        </div>
                      </section>
                    );
                  })
                }
              </div>
            </section>
          );
        })
      }
    </div>
  </div>
</section>