---
const {
  families = [],
  equipment = [],
  rubroLabel = "Industria textil",
} = Astro.props;

const getEquipment = (familyId, subgroupId) =>
  equipment
    .filter(
      (item) =>
        item.family === familyId &&
        item.subgroup === subgroupId,
    )
    .sort((a, b) => (a.order ?? 999) - (b.order ?? 999));

const getFamilyCount = (familyId) =>
  equipment.filter((item) => item.family === familyId).length;
---

<section
  class="rubro-equipment-groups"
  aria-labelledby="equipment-groups-title"
>
  <div class="rubro-section__inner">
    <header class="rubro-section__heading rubro-equipment-groups__heading">
      <p class="rubro-eyebrow">Equipos y soluciones</p>

      <h2 id="equipment-groups-title">
        Tecnología organizada según cada etapa de producción.
      </h2>

      <p>
        Explorá las familias de equipos disponibles para {rubroLabel}.
        La configuración adecuada depende del material, el volumen, el formato
        y el proceso que necesitás resolver.
      </p>
    </header>

    <nav
      class="rubro-family-navigation"
      aria-label={`Familias de equipos para ${rubroLabel}`}
    >
      {
        families.map((family) => (
          <a href={`#familia-${family.id}`}>
            <span>{family.number}</span>

            <strong>{family.title}</strong>

            <small>
              {getFamilyCount(family.id)}
              {" "}
              {getFamilyCount(family.id) === 1 ? "equipo" : "equipos"}
            </small>
          </a>
        ))
      }
    </nav>

    <div class="rubro-equipment-families">
      {
        families.map((family) => {
          const familyCount = getFamilyCount(family.id);

          if (familyCount === 0) {
            return null;
          }

          return (
            <section
              class="rubro-equipment-family"
              id={`familia-${family.id}`}
              aria-labelledby={`titulo-${family.id}`}
            >
              <header class="rubro-equipment-family__header">
                <span>{family.number}</span>

                <div>
                  <h3 id={`titulo-${family.id}`}>
                    {family.title}
                  </h3>

                  <p>{family.description}</p>
                </div>

                <small>
                  {familyCount}
                  {" "}
                  {familyCount === 1 ? "equipo" : "equipos"}
                </small>
              </header>

              <div class="rubro-equipment-family__subgroups">
                {
                  family.subgroups.map((subgroup) => {
                    const subgroupEquipment = getEquipment(
                      family.id,
                      subgroup.id,
                    );

                    if (subgroupEquipment.length === 0) {
                      return null;
                    }

                    return (
                      <section
                        class="rubro-equipment-subgroup"
                        aria-labelledby={`subgrupo-${family.id}-${subgroup.id}`}
                      >
                        <header class="rubro-equipment-subgroup__header">
                          <div>
                            <h4
                              id={`subgrupo-${family.id}-${subgroup.id}`}
                            >
                              {subgroup.title}
                            </h4>

                            <p>{subgroup.description}</p>
                          </div>

                          <span>
                            {subgroupEquipment.length}
                            {" "}
                            {subgroupEquipment.length === 1
                              ? "modelo"
                              : "modelos"}
                          </span>
                        </header>

                        <div class="rubro-equipment-subgroup__grid">
                          {
                            subgroupEquipment.map((item) => (
                              <article class="rubro-equipment-product">
                                <div class="rubro-equipment-product__image">
                                  <img
                                    src={item.image}
                                    alt={`${item.brand} ${item.name}`}
                                    width="720"
                                    height="480"
                                    loading="lazy"
                                    decoding="async"
                                  />

                                  {item.hasVideo && (
                                    <span class="rubro-equipment-product__video">
                                      Video disponible
                                    </span>
                                  )}
                                </div>

                                <div class="rubro-equipment-product__content">
                                  <p class="rubro-equipment-product__brand">
                                    {item.brand}
                                  </p>

                                  <h5>{item.name}</h5>

                                  <p>{item.shortDescription}</p>
                                </div>

                                <div class="rubro-equipment-product__footer">
                                  {item.hasPdf && (
                                    <span>Ficha técnica disponible</span>
                                  )}

                                  {
                                    item.pageReady ? (
                                      <a href={`/equipos/${item.id}`}>
                                        Ver equipo
                                        <span aria-hidden="true">→</span>
                                      </a>
                                    ) : (
                                      <a
                                        href={`/#contacto?equipo=${encodeURIComponent(item.name)}`}
                                      >
                                        Consultar
                                        <span aria-hidden="true">→</span>
                                      </a>
                                    )
                                  }
                                </div>
                              </article>
                            ))
                          }
                        </div>
                      </section>
                    );
                  })
                }
              </div>
            </section>
          );
        })
      }
    </div>
  </div>
</section>