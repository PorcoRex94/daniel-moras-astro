---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: CollectionEntry<"blog">;
  headings: Heading[];
}

const { post, headings = [] } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("es-AR", {
  day: "2-digit",
  month: "long",
  year: "numeric",
}).format(post.data.pubDate);

const siteUrl = Astro.site?.origin ?? "https://daniel-moras-astro.vercel.app";
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${pageUrl}#article`,
  headline: post.data.title,
  description: post.data.description,
  image: new URL(post.data.image, siteUrl).toString(),
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: "Daniel Moras",
  },
  publisher: {
    "@id": `${siteUrl}/#organization`,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": pageUrl,
  },
  inLanguage: "es-AR",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: siteUrl,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: `${siteUrl}/blog`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: pageUrl,
    },
  ],
};
---

<BaseLayout
  title={`${post.data.title} | Daniel Moras`}
  description={post.data.description}
  image={post.data.image}
  type="article"
  schema={[articleSchema, breadcrumbSchema]}
>
  <main class="blog-post-page">
    <div class="section-divider">
      <span>Blog</span>
    </div>

    <article class="blog-post">
      <div class="blog-post__layout">
        <header class="blog-post__header">
          <nav class="blog-breadcrumbs" aria-label="Breadcrumb">
            <a href="/">Inicio</a>
            <span>/</span>
            <a href="/blog">Blog</a>
            <span>/</span>
            <strong>{post.data.category}</strong>
          </nav>

          <h1>{post.data.title}</h1>

          <p>{post.data.description}</p>

          <div class="blog-post__meta">
            <span class="blog-post__category">{post.data.category}</span>
            <time datetime={post.data.pubDate.toISOString()}>
              {formattedDate}
            </time>
          </div>

          <a href="/blog" class="blog-post__back">Volver al blog</a>
        </header>

        <aside class="blog-post__aside" aria-label="Resumen de la nota">
          <div class="blog-post__aside-inner">
            <div class="blog-post__image">
              <img src={post.data.image} alt={post.data.imageAlt ?? ""} />
            </div>

            {
              headings.length > 0 && (
                <nav class="blog-post__toc" aria-label="Contenido de la nota">
                  <p>En esta nota</p>

                  <ol>
                    {headings.map((heading) => (
                      <li>
                        <a href={`#${heading.slug}`}>{heading.text}</a>
                      </li>
                    ))}
                  </ol>
                </nav>
              )
            }
          </div>
        </aside>

        <div class="blog-post__body">
          <slot />
        </div>
      </div>
    </article>
  </main>
</BaseLayout>