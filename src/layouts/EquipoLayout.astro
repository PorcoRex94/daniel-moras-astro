---
import BaseLayout from "./BaseLayout.astro";
import { equipos } from "../data/equipos";

const { equipo } = Astro.props;

const rubroLabels = {
  packaging: "Packaging",
  textil: "Industria textil",
  editorial: "Editorial",
  etiquetas: "Etiquetas",
  comunicacionVisual: "Comunicación visual",
};

const rubroUrls = {
  packaging: "/rubros/packaging",
  textil: "/rubros/textil",
  editorial: "/rubros/editorial",
  etiquetas: "/rubros/etiquetas",
  comunicacionVisual: "/rubros/comunicacion-visual",
};

const relatedEquipos = equipos
  .filter(
    (item) =>
      item.id !== equipo.id &&
      item.rubros.some((rubro) => equipo.rubros.includes(rubro)),
  )
  .slice(0, 3);

const siteUrl = Astro.site?.origin ?? "https://daniel-moras-astro.vercel.app";
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: siteUrl,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Equipos",
      item: `${siteUrl}/equipos`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: equipo.name,
      item: pageUrl,
    },
  ],
};

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${pageUrl}#webpage`,
  name: equipo.name,
  description: equipo.description,
  url: pageUrl,
  image: new URL(equipo.image, siteUrl).toString(),
};
---

<BaseLayout
  title={`${equipo.name} | Daniel Moras`}
  description={equipo.description}
  image={equipo.image}
  schema={[breadcrumbSchema, pageSchema]}
>
  <main class="equipo-page">
    <section class="equipo-hero">
      <div class="equipo-hero__inner">
        <div class="equipo-hero__content">
          <nav class="equipo-breadcrumbs" aria-label="Breadcrumb">
            <a href="/">Inicio</a>
            <span>/</span>
            <a href="/equipos">Equipos</a>
            <span>/</span>
            <strong>{equipo.name}</strong>
          </nav>

          <p class="equipos-eyebrow">{equipo.category}</p>

          <h1>{equipo.name}</h1>

          <p>{equipo.description}</p>

          <a href="/#contacto" class="equipo-hero__cta">
            Consultar por esta solución
          </a>
        </div>

        <div class="equipo-hero__media">
          <img src={equipo.image} alt={equipo.name} />
        </div>
      </div>
    </section>

    <section class="equipo-detail">
      <div class="equipos-section__inner equipo-detail__inner">
        <div class="equipo-detail__main">
          {
            equipo.video?.url && (
              <section class="equipo-video">
                <header>
                  <p class="equipos-eyebrow">Video</p>
                  <h2>Video del equipo o solución.</h2>
                </header>

                <div class="equipo-video__frame">
                  <iframe
                    src={equipo.video.url}
                    title={`Video de ${equipo.name}`}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                  />
                </div>
              </section>
            )
          }

          <section class="equipo-info-block">
            <header>
              <p class="equipos-eyebrow">Aplicaciones</p>
              <h2>Aplicaciones frecuentes.</h2>
            </header>

            <div class="equipo-list">
              {
                equipo.applications.map((item) => (
                  <article>
                    <span>✓</span>
                    <p>{item}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section class="equipo-info-block">
            <header>
              <p class="equipos-eyebrow">Características</p>
              <h2>Aspectos a evaluar.</h2>
            </header>

            <div class="equipo-list">
              {
                equipo.features.map((item) => (
                  <article>
                    <span>•</span>
                    <p>{item}</p>
                  </article>
                ))
              }
            </div>
          </section>
        </div>

        <aside class="equipo-detail__aside">
          <div class="equipo-aside-card">
            <p class="equipos-eyebrow">Rubros</p>

            <h2>Rubros donde puede aplicar.</h2>

            <div class="equipo-rubros">
              {
                equipo.rubros.map((rubro) => (
                  <a href={rubroUrls[rubro]}>
                    {rubroLabels[rubro]}
                  </a>
                ))
              }
            </div>
          </div>

          <div class="equipo-aside-card equipo-aside-card--dark">
            <h2>¿Querés evaluar esta solución?</h2>

            <p>
              Contanos material, volumen, aplicación y proceso actual para
              orientar mejor la recomendación.
            </p>

            <a href="/#contacto">Hacer una consulta</a>
          </div>
        </aside>
      </div>
    </section>

    {
      relatedEquipos.length > 0 && (
        <section class="equipos-related">
          <div class="equipos-section__inner">
            <header class="equipos-section__heading">
              <p class="equipos-eyebrow">Relacionados</p>
              <h2>Otros equipos que pueden interesarte.</h2>
            </header>

            <div class="equipos-grid equipos-grid--related">
              {relatedEquipos.map((item) => (
                <a href={`/equipos/${item.id}`} class="equipo-card">
                  <div class="equipo-card__image">
                    <img src={item.image} alt={item.name} loading="lazy" />
                  </div>

                  <div class="equipo-card__content">
                    <span>{item.category}</span>
                    <h2>{item.name}</h2>
                    <p>{item.description}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }
  </main>
</BaseLayout>