---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog | Daniel Moras"
  description="Notas técnicas sobre impresión industrial, tecnología Inkjet, sublimación, UV, packaging, etiquetas, tintas e insumos."
>
  <main class="blog-page">
    <div class="section-divider">
      <span>Blog</span>
    </div>

    <Container>
      <header class="blog-page__heading">
        <h1>Notas técnicas y novedades.</h1>

        <p>
          Contenidos pensados para entender tecnologías, aplicaciones, tintas,
          materiales y criterios de inversión antes de elegir una solución de
          impresión.
        </p>
      </header>

      <div class="blog-page__grid">
        {
          posts.map((post) => (
            <article class="blog-card">
              <a
                href={`/blog/${post.id}`}
                class="blog-card__image"
                aria-label={post.data.title}
              >
                <img src={post.data.image} alt={post.data.imageAlt ?? ""} />
              </a>

              <div class="blog-card__content">
                <span>{post.data.category}</span>

                <h2>
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>

                <p>{post.data.description}</p>

                <a href={`/blog/${post.id}`} class="blog-card__link">
                  Leer nota
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </Container>
  </main>
</BaseLayout>